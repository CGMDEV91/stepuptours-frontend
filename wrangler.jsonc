{
  "name": "stepuptours",
  "compatibility_date": "2026-04-14",
  "main": "worker.js",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS"
  },
  "vars": {
    "DRUPAL_API_URL": "https://stepuptours.com"
  },
  "routes": [
    { "pattern": "stepuptours.com", "custom_domain": true },
    { "pattern": "www.stepuptours.com", "custom_domain": true }
  ]
}
